.DS_Store

# Generated artifacts — rebuilt from the newest src/*.md at build time.
# Never commit these (see CLAUDE.md golden rule): the next build overwrites them.
_site/
index.md
_body.md

# Jekyll / Bundler local state (never checked in; regenerated on each build).
.jekyll-cache/
.jekyll-metadata
.sass-cache/
.bundle/
vendor/

# Python bytecode cache from build_page.py (regenerated; version/platform specific).
__pycache__/
*.py[cod]